# ============================================================
# Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# Supabase
DATABASE_URL=postgresql://postgres:your_password@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Segurança JWT
SECRET_KEY=your_very_long_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=UrbanReport API
APP_VERSION=1.0.0
DEBUG=True

# CORS — origens permitidas (separe por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Keep-alive - URL publica do backend no Render
BACKEND_URL=https://seu-app.onrender.com

# Upload de imagens - Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MAX_UPLOAD_SIZE_MB=5
